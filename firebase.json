{
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/",
        "destination": "/landing.html"
      }
    ],
    "redirects": [
      {
        "source": "/index.html",
        "destination": "/app.html",
        "type": 302
      }
    ],
    "headers": [
      {
        "source": "**/*.@(html|xml|txt)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"
          }
        ]
      }
    ]
  }
}
